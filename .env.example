# ===================== Core Runtime (required/recommended) =====================
# [required for online deploy] Runtime mode: local | online
WEBUI_V2_MODE=local
# [recommended] API server bind and logging for WebUI v2
WEBUI_V2_HOST=0.0.0.0
WEBUI_V2_PORT=7861
WEBUI_V2_LOG_LEVEL=info
# [recommended] Frontend serving mode
WEBUI_V2_FRONTEND_DIST=frontend/dist
WEBUI_V2_DEV_MODE=0
WEBUI_V2_FRONTEND_DEV_URL=http://127.0.0.1:5173
# [optional] Comma-separated CORS allowlist
WEBUI_V2_CORS_ORIGINS=http://127.0.0.1:7861,http://localhost:7861,http://127.0.0.1:5173,http://localhost:5173
# [optional; security-sensitive] Allow non-localhost access to /api/settings/env
WEBUI_V2_ALLOW_REMOTE_SETTINGS=0

# ===================== WebUI V2 Limits (mode-based) =====================
# [online only] Max FASTA record count per run in Quick/Advanced
WEBUI_V2_ONLINE_FASTA_LIMIT=50
# [online only] Max designed sequences per Sequence Design run
WEBUI_V2_ONLINE_SEQUENCE_DESIGN_LIMIT=50
# [online only] Max new chat requests per user/IP per day
WEBUI_V2_ONLINE_DAILY_CHAT_LIMIT=10
# [online only] Session token TTL and signing secret
WEBUI_V2_SESSION_TOKEN_TTL_HOURS=24
WEBUI_V2_SESSION_TOKEN_SECRET=
# Download batch caps
# [local] 0 means unlimited
WEBUI_V2_LOCAL_DOWNLOAD_BATCH_LIMIT=0
# [online] hard cap
WEBUI_V2_ONLINE_DOWNLOAD_BATCH_LIMIT=50

# ===================== LLM / AI Keys =====================
# [conditional] Required when using LLM-backed features
OPENAI_API_KEY=
# [optional] Some legacy Gradio paths also check this key name
DEEPSEEK_API_KEY=
# [optional] LLM endpoint and model
CHAT_BASE_URL=https://www.dmxapi.cn/v1
CHAT_MODEL_NAME=gemini-2.5-pro
CHAT_MAX_TOKENS=8192
CHAT_CODE_MAX_TOKENS=10000
# [optional] LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=pr-new-twitter-89

# ===================== Search / External APIs =====================
# [conditional] Required for corresponding tools only
TAVILY_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
FDA_API_KEY=
BRENDA_EMAIL=
BRENDA_PASSWORD=

# ===================== Agent Behavior =====================
# [optional] Search fan-out / reasoning retries / tool timeout
SEARCH_MAX_RESULTS=3
MAX_STEP_RETRIES=2
TOOL_EXECUTION_TIMEOUT=600
# Legacy keys below are kept for reference; v2 runtime does not read them:
# AGENT_CHAT_MAX_MESSAGES=200
# AGENT_CHAT_MAX_TOOL_CALLS=500
# AGENT_CHAT_MAX_STEP_RETRIES=2  # replaced by MAX_STEP_RETRIES

# ===================== Storage / Temp Outputs =====================
# [recommended] Root for generated artifacts
TEMP_OUTPUTS_DIR=temp_outputs
# [optional] TTL cleanup switches
TEMP_OUTPUTS_ENABLE_TTL_CLEANUP=0
TEMP_OUTPUTS_UPLOADS_TTL_DAYS=7
TEMP_OUTPUTS_WORK_TTL_DAYS=2
TEMP_OUTPUTS_RESULTS_TTL_DAYS=14
TEMP_OUTPUTS_SESSIONS_TTL_DAYS=3
TEMP_OUTPUTS_MANIFESTS_TTL_DAYS=30
TEMP_OUTPUTS_CACHE_TTL_DAYS=7
# Legacy fallback key used by some cleanup paths
TEMP_OUTPUTS_AGENT_TTL_DAYS=3

# ===================== MCP / Remote / DrugSDA =====================
# [recommended] MCP server bind
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
# [conditional] Remote structure backend (pjlab) credentials and endpoints
SCP_HUB_API_KEY=
AGENT_ESMFOLD_DEFAULT_BACKEND=local
SCP_WORKFLOW_SERVER_URL=http://115.190.136.251:8080/mcp
DRUGSDA_MODEL_SERVER_URL=https://scp.intern-ai.org.cn/api/v1/mcp/3/DrugSDA-Model
DRUGSDA_TOOL_SERVER_URL=https://scp.intern-ai.org.cn/api/v1/mcp/2/DrugSDA-Tool
# Optional MMseqs DB paths for discovery-related features
VENUSMINE_MMSEQS_DATABASE_PATH=
MMSEQS_DATABASE_PATH=

# ===================== Hugging Face / Data =====================
# [optional] Mirror for model downloads
# HF_ENDPOINT=https://hf-mirror.com
# [optional] Sequence model cache root
PT_DATA_DIR=

# ===================== Legacy / Compatibility (optional) =====================
# Legacy env names retained for backward notes (may be unused in v2 runtime):
# AGENT_DEFAULT_BACKEND=local
# GRADIO_BASE_URL=http://localhost:7860/

# ===================== Advanced Debug (optional) =====================
CUSTOM_MODEL_DEBUG_LOG_PATH=
TRAIN_ARGS_DEBUG_LOG_PATH=
ADAPTER_MODEL_DEBUG_LOG_PATH=
BRENDA_DEBUG=

# ===================== Docker / Build =====================
VENUS_FACTORY_VERSION_NUMBER=
# e.g. cpu, cu128
VENUS_FACTORY_CUDA_VARIANT=
VENUS_FEEDBACK_WEBHOOK_URL=