# ========== Hugging Face (optional) ==========
# Mirror for model downloads; leave empty to use default
# HF_ENDPOINT=https://hf-mirror.com

# ========== LLM / API Keys ==========
# Used by agent, training pipeline, and advanced-tool AI analysis
OPENAI_API_KEY=
# LLM base URL (chat agent + training code execution)
# e.g. https://www.dmxapi.cn/v1, https://api.openai.com/v1
CHAT_BASE_URL=https://www.dmxapi.cn/v1
# Chat / code-gen model (chat_agent Chat_LLM + training tools_mcp)
CHAT_MODEL_NAME=gemini-2.5-pro
# Max tokens per LLM reply (chat agent); default 8192 so research draft is not cut off
CHAT_MAX_TOKENS=8192
# Token limit for code generation (training tools_mcp)
CHAT_CODE_MAX_TOKENS=10000

# ========== Search / misc (optional) ==========
TAVILY_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
FDA_API_KEY=
# BRENDA enzyme database SOAP API (optional; required for BRENDA tools)
BRENDA_EMAIL=
BRENDA_PASSWORD=
SEARCH_MAX_RESULTS=3

# ========== Gradio / MCP ==========
# Default backend for agent tools: local (local paths only) or pjlab (upload via SCP)
AGENT_DEFAULT_BACKEND=local
# Gradio app URL (same for local and pjlab; pjlab uses SCP for uploads and shareable URLs)
GRADIO_BASE_URL=http://localhost:7860/
# MCP Server
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080

# ========== SCP / Upload ==========
# SCP Workflow server used when endpoint=pjlab for file uploads
SCP_HUB_API_KEY=
# Default backend when not passed: local (GPU) or pjlab (DrugSDA remote)
AGENT_ESMFOLD_DEFAULT_BACKEND=local
# When backend=pjlab: SCP workflow server for file uploads (no separate Gradio URL needed)
SCP_WORKFLOW_SERVER_URL=http://115.190.136.251:8080/mcp
DRUGSDA_MODEL_SERVER_URL="https://scp.intern-ai.org.cn/api/v1/mcp/3/DrugSDA-Model"
DRUGSDA_TOOL_SERVER_URL="https://scp.intern-ai.org.cn/api/v1/mcp/2/DrugSDA-Tool"
# Default backend when not passed: local (GPU) or pjlab (DrugSDA remote)
AGENT_ESMFOLD_DEFAULT_BACKEND=pjlab


# ========== Agent chat limits (free use, one chat session) ==========
# Maximum number of conversation messages (user + assistant) in one chat
AGENT_CHAT_MAX_MESSAGES=50
# Maximum number of tool calls in one chat
AGENT_CHAT_MAX_TOOL_CALLS=40
# Max step-level retries after MLS self-check (failure, timeout, or tool success:false); default 2
AGENT_CHAT_MAX_STEP_RETRIES=2

# ========== Temp output directory ==========
# Root for get_save_path (default temp_outputs), then year/month/day/subdirs
TEMP_OUTPUTS_DIR=temp_outputs

# ========== Docker / Build ==========
VENUS_FACTORY_VERSION_NUMBER=
# e.g. cpu, cu128
VENUS_FACTORY_CUDA_VARIANT=
